# Local LightRAG build profile for the RAG_LUND machine.
# Copy this file to configs/local-qwen3vl.env and edit secrets/paths there.

# ---------------------------------------------------------------------------
# Workspace and storage
# ---------------------------------------------------------------------------
WORKSPACE=internal_lightrag
WORKING_DIR=/data/y50056788/Yaliang/internal_lightrag/rag_workspace
INPUT_DIR=/data/y50056788/Yaliang/internal_lightrag/inputs
REPORT_DIR=/data/y50056788/Yaliang/internal_lightrag/reports

LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
LIGHTRAG_VECTOR_STORAGE=QdrantHybridBM25VectorDBStorage

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_ENABLE_SPARSE_BM25=true
QDRANT_SPARSE_BM25_MODEL=Qdrant/bm25
QDRANT_RETRIEVAL_MODE=hybrid
QDRANT_COLLECTION_PREFIX=local_lightrag_bm25
# QDRANT_FASTEMBED_CACHE_DIR=/data/y50056788/Yaliang/fastembed_cache

# ---------------------------------------------------------------------------
# Qwen3-VL LLM/VLM, same endpoint convention as RAG_LUND.
# ---------------------------------------------------------------------------
VLLM_API_BASE=http://localhost:8001/v1
VLLM_API_KEY=EMPTY
LLM_MODEL_NAME=Qwen/Qwen3-VL-30B-A3B-Instruct-FP8
LLM_TOKENIZER_MODEL_PATH=/data/y50056788/Yaliang/models/Qwen3-VL-30B-A3B-Instruct-FP8
LLM_TIMEOUT=1800

# The build script uses this endpoint for both text LLM and VLM roles.
VLM_PROCESS_ENABLE=true
VLM_MAX_ASYNC_LLM=2
VLM_MAX_IMAGE_BYTES=5242880

# ---------------------------------------------------------------------------
# Local in-process embedding/reranker. These are not HTTP endpoints.
# ---------------------------------------------------------------------------
RAGANYTHING_EMBEDDING_MODEL_PATH=/data/h50056787/models/bge-m3
RAGANYTHING_RERANK_MODEL_PATH=/data/h50056787/models/bge-reranker-v2-m3
RAGANYTHING_DEVICE=cuda:0
RAGANYTHING_EMBEDDING_DIM=1024
RAGANYTHING_EMBEDDING_BATCH_NUM=4
RAGANYTHING_RERANK_BATCH_SIZE=8

# ---------------------------------------------------------------------------
# Indexing/query limits
# ---------------------------------------------------------------------------
MAX_PARALLEL_INSERT=2
MAX_ASYNC=16
MAX_ASYNC_RERANK=1
EMBEDDING_FUNC_MAX_ASYNC=4
EMBEDDING_BATCH_NUM=4
MAX_PARALLEL_PARSE_NATIVE=2
MAX_PARALLEL_PARSE_MINERU=1
MAX_PARALLEL_PARSE_DOCLING=1
MAX_PARALLEL_ANALYZE=2
MAX_EXTRACT_INPUT_TOKENS=20480
EMBEDDING_TOKEN_LIMIT=8192

CHUNK_SIZE=1200
CHUNK_OVERLAP_SIZE=100
TOP_K=40
CHUNK_TOP_K=20
RELATED_CHUNK_NUMBER=5
MAX_ENTITY_TOKENS=6000
MAX_RELATION_TOKENS=8000
MAX_TOTAL_TOKENS=30000
MAX_SOURCE_IDS_PER_ENTITY=999999
MAX_SOURCE_IDS_PER_RELATION=999999
SOURCE_IDS_LIMIT_METHOD=FIFO
MIN_RERANK_SCORE=0.3
RERANK_BY_DEFAULT=true

# Reuse RAG_LUND LibreOffice-converted PDFs when present. Missing PDFs fall
# back to the original Office file so the official LightRAG parser can handle it.
REUSE_DEV_LIBREOFFICE_PDFS=true
DEV_LIBREOFFICE_PDF_ROOT=/data/y50056788/Yaliang/internal/output/internal

# ---------------------------------------------------------------------------
# Parser routing. Text files use legacy text ingestion. Rich documents/images
# use official LightRAG MinerU pending-parse flow.
# ---------------------------------------------------------------------------
LIGHTRAG_PARSER=pdf:mineru-iteP,doc:mineru-iteP,docx:mineru-iteP,ppt:mineru-iteP,pptx:mineru-iteP,xls:mineru-iteP,xlsx:mineru-iteP,png:mineru-iteP,jpg:mineru-iteP,jpeg:mineru-iteP,bmp:mineru-iteP,gif:mineru-iteP,webp:mineru-iteP,txt:legacy-F,md:legacy-F

MINERU_API_MODE=local
MINERU_LOCAL_ENDPOINT=http://127.0.0.1:8000
MINERU_LOCAL_BACKEND=hybrid-auto-engine
MINERU_LOCAL_PARSE_METHOD=auto
MINERU_LOCAL_IMAGE_ANALYSIS=true
MINERU_POLL_INTERVAL_SECONDS=5
MINERU_MAX_POLLS=720
